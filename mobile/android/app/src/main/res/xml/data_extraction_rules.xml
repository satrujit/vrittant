<?xml version="1.0" encoding="utf-8"?>
<!--
  Android 12+ (API 31+) backup rules.
  We exclude flutter_secure_storage's EncryptedSharedPreferences (where the JWT lives)
  and the legacy plain SharedPreferences fallback, so a device-to-device transfer or
  cloud backup can't carry over a logged-in session.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="FlutterSecureStorage.xml"/>
        <exclude domain="sharedpref" path="FlutterSharedPreferences.xml"/>
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="FlutterSecureStorage.xml"/>
        <exclude domain="sharedpref" path="FlutterSharedPreferences.xml"/>
    </device-transfer>
</data-extraction-rules>
