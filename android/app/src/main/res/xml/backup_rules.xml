<?xml version="1.0" encoding="utf-8"?>
<!--
  Android 11- (API 30 and below) backup rules.
  Same intent as data_extraction_rules.xml: never let a backup carry the auth session.
-->
<full-backup-content>
    <exclude domain="sharedpref" path="FlutterSecureStorage.xml"/>
    <exclude domain="sharedpref" path="FlutterSharedPreferences.xml"/>
</full-backup-content>
