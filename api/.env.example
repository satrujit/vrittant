# Vrittant API — Environment Configuration
# Copy to .env and fill in values

# Environment: "dev" | "uat" | "prod"
ENV=dev

# Database — SQLite for local, PostgreSQL for UAT/prod
DATABASE_URL=sqlite:///./newsflow.db
# DATABASE_URL=postgresql://user:pass@host:5432/vrittant

# Auth
SECRET_KEY=change-me-to-a-random-256-bit-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_DAYS=90

# CORS — comma-separated origins
CORS_ORIGINS=http://localhost:5173,http://localhost:5175

# Firebase
FIREBASE_PROJECT_ID=vrittant-f5ef2

# Sarvam AI
SARVAM_API_KEY=
SARVAM_BASE_URL=https://api.sarvam.ai

# OpenAI (optional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# MSG91 OTP
MSG91_AUTHKEY=
MSG91_TEMPLATE_ID=
MSG91_WIDGET_ID=
MSG91_TOKEN_AUTH=

# File Storage — "local" or "gcs"
STORAGE_BACKEND=local
GCS_BUCKET=
